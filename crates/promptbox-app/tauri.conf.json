{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptHarbor",
  "version": "0.1.0",
  "identifier": "com.insistanan.promptharbor",
  "build": {
    "beforeDevCommand": "npm --prefix ../../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../../frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "提示港 PromptHarbor",
        "width": 760,
        "height": 560,
        "minWidth": 680,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "resources": ["resources/"],
    "targets": "all"
  }
}
